# ============================================================
# HotelBoss - Environment Variables Example
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/hotelboss
DB_USER=hotelboss
DB_PASSWORD=hotelboss

# ------------------------------------------------------------
# Keycloak (OAuth2 / JWT)
# ------------------------------------------------------------
# Issuer URI for the Spring Boot resource server to validate JWTs
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/hotelboss

# Keycloak admin credentials (for docker-compose setup)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ------------------------------------------------------------
# Azure Storage Queue
# ------------------------------------------------------------
# For local development with Azurite emulator:
AZURE_QUEUE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OGLjX+Y96tu9bOa/S7oFtfOrEWpo+4Kg==;QueueEndpoint=http://localhost:10001/devstoreaccount1;

# For production (Azure Storage Account):
# AZURE_QUEUE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-account>;AccountKey=<your-key>;EndpointSuffix=core.windows.net

AZURE_QUEUE_NAME=booking-confirmations

# ------------------------------------------------------------
# Frontend (Next.js) - Public environment variables
# ------------------------------------------------------------
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8180
NEXT_PUBLIC_KEYCLOAK_REALM=hotelboss
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=hotel-frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api
